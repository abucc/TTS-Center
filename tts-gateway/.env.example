# Authentication Configuration
SESSION_SECRET=your_session_secret_here
AUTH_USERNAME=your_username_here
AUTH_PASSWORD_HASH=your_password_hash_here

# General settings
CORS_ORIGINS=*
REDIS_ENABLED=true
REDIS_KEY_PREFIX=tts_
REDIS_URL=redis://username:password@host:port/db_number

S3_ENABLED=true
S3_ACCESS_KEY=your_s3_access_key
S3_BUCKET_NAME=your_bucket_name
S3_ENDPOINT_URL=https://your.minio.endpoint
S3_PUBLIC_URL=
S3_REGION=us-east-1
S3_SECRET_KEY=your_s3_secret_key

PUBLIC_URL=https://your.public.url

API_KEY=your_api_key_here
DEFAULT_VOICE=en-US-AvaNeural
DEFAULT_RESPONSE_FORMAT=mp3
DEFAULT_SPEED=1.0
DEFAULT_LANGUAGE=en-US
REQUIRE_API_KEY=true
REMOVE_FILTER=false
EXPAND_API=true
DETAILED_ERROR_LOGGING=true

CHATTERBOX_URL=http://chatterbox-tts:9001
KOKORO_URL=http://kokoro-onnx:9002
OPENAI_EDGE_TTS_URL=http://openai-edge-tts:5050
PORT=5050
