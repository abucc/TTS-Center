# TTS Gateway Environment Variables

# Core Settings
PORT=9000
CORS_ORIGINS=*

# Redis Cache Settings
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_KEY_PREFIX=tts_
# Or use Redis URL (for Coolify)
# REDIS_URL=redis://username:password@redis:6379/1

# Service URLs
KOKORO_URL=http://kokoro-onnx:9002
CHATTERBOX_URL=http://chatterbox-tts:9001
OPENAI_EDGE_TTS_URL=http://openai-edge-tts:5050

# S3 Compatible Storage (AWS S3, DigitalOcean Spaces, etc.)
# Set to true to enable S3 storage
S3_ENABLED=false
S3_ENDPOINT_URL=https://your-endpoint.com
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=your-region

# Optional - Custom public URL for S3 objects (e.g., CDN)
# S3_PUBLIC_URL=https://cdn.your-domain.com

# Base URL for public file access
PUBLIC_URL=https://tts.dahopevi.com
