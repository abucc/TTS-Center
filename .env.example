# Example .env file for Awesome-TTS with cloud storage configuration

# General settings
CORS_ORIGINS=*
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/1
REDIS_KEY_PREFIX=tts_

# S3 Storage Configuration 
# Set to true to enable cloud storage
S3_ENABLED=false

# S3-compatible storage settings (AWS S3, DigitalOcean Spaces, etc.)
S3_ENDPOINT_URL=https://your-region.digitaloceanspaces.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=your-region

# Optional: Custom public URL for your files (e.g., CDN)
# S3_PUBLIC_URL=https://cdn.yourdomain.com

# Base URL for your application (used for constructing audio URLs)
PUBLIC_URL=https://your-domain.com

# Main API Configuration:
# API_KEY - General authentication key for tts-gateway and internal services
API_KEY=your_api_key # (Same for API Gateway and OPENAI_EDGE_TTS API)
DEFAULT_VOICE=en-US-AvaNeural
DEFAULT_RESPONSE_FORMAT=mp3
DEFAULT_SPEED=1.0
DEFAULT_LANGUAGE=en-US
REQUIRE_API_KEY=false
REMOVE_FILTER=false
EXPAND_API=true
DETAILED_ERROR_LOGGING=true

# Authentication Configuration (required for session management)
SESSION_SECRET=your-secret-key-change-this
AUTH_USERNAME=admin
AUTH_PASSWORD=your_password

# TTS Service URLs
CHATTERBOX_URL=http://chatterbox-tts:9001
KOKORO_URL=http://kokoro-onnx:9002
OPENAI_EDGE_TTS_URL=http://openai-edge-tts:5050

# OpenAI Edge TTS Configuration:
OPENAI_EDGE_TTS_API_KEY=your_openai_edgetts_api_key # Internally used by TTS Gateway to authenticate with openai-edge-tts service
PORT=9000
