AUTH_USERNAME=admin
AUTH_PASSWORD=change-me
SESSION_SECRET=change-this-long-random-string

# Browser UI calls this API URL. Leave empty to use http://<same-host>:9000.
VITE_API_BASE=

# Windows Qwen bridge. On the NAS, set this to the PC LAN address.
QWEN_URL=http://192.168.31.167:7861
QWEN_TIMEOUT=900

# Hermes Aliyun skill fallback. The compose file mounts:
# /volume1/docker/hermes-agent/data -> /opt/data
ALIYUN_DEFAULT_VOICE=zhimi_emo
ALIYUN_OUTPUT_FORMAT=wav
ALIYUN_TIMEOUT=180
ALIYUN_TTS_COMMAND=/usr/local/bin/python /opt/data/skills/aliyun-tts/scripts/aliyun_tts.py {text_file} {output_path} --voice {voice} --format {format}
VOICE_STYLE_PATH=/opt/data/voice_styles.json
VOICE_HUB_TARGET_TTS_CHARS=80
VOICE_HUB_MAX_TTS_CHARS=120

REQUIRE_API_KEY=false
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
NPM_REGISTRY=https://registry.npmmirror.com
