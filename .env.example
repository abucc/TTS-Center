# Example .env file for Awesome-TTS with cloud storage configuration

# General settings
CORS_ORIGINS=*
REDIS_ENABLED=true
REDIS_URL=redis://redis:6379/1
REDIS_KEY_PREFIX=tts_

# S3 Storage Configuration 
# Set to true to enable cloud storage
S3_ENABLED=true

# S3-compatible storage settings (AWS S3, DigitalOcean Spaces, etc.)
S3_ENDPOINT_URL=https://your-region.digitaloceanspaces.com
S3_ACCESS_KEY=your_access_key
S3_SECRET_KEY=your_secret_key
S3_BUCKET_NAME=your-bucket-name
S3_REGION=your-region

# Optional: Custom public URL for your files (e.g., CDN)
# S3_PUBLIC_URL=https://cdn.yourdomain.com

# Base URL for your application (used for constructing audio URLs)
PUBLIC_URL=https://tts.dahopevi.com

# API Keys for services that require them
API_KEY=your_api_key
DEFAULT_VOICE=alloy
DEFAULT_RESPONSE_FORMAT=mp3
DEFAULT_SPEED=1.0
DEFAULT_LANGUAGE=en-US
REQUIRE_API_KEY=false
REMOVE_FILTER=true
EXPAND_API=true
DETAILED_ERROR_LOGGING=true
